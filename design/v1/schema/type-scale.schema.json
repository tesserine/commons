{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tesserine type scale",
  "description": "Structural guard for design/v1/type-scale.json. Internal to the design system's home; design/v1/SYSTEM.md is the prose authority.",
  "type": "object",
  "required": ["family", "version", "governing_fact", "base", "ratio", "members"],
  "additionalProperties": false,
  "properties": {
    "family": { "const": "type-scale" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "governing_fact": { "type": "string", "minLength": 1 },
    "base": { "type": "string", "pattern": "^[0-9.]+rem$" },
    "ratio": { "type": "number", "exclusiveMinimum": 1 },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "power", "size", "line_height", "role", "derivation"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^type\\.[a-z][a-z0-9-]*$" },
          "power": { "type": "integer" },
          "size": { "type": "string", "pattern": "^[0-9.]+rem$" },
          "line_height": { "type": "number", "exclusiveMinimum": 0 },
          "role": { "type": "string", "minLength": 1 },
          "derivation": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
