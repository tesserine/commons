{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tesserine design tokens",
  "description": "Structural guard for design/v1/tokens.json. Internal to the design system's home; design/v1/SYSTEM.md is the prose authority.",
  "type": "object",
  "required": ["family", "version", "governing_fact", "members"],
  "additionalProperties": false,
  "properties": {
    "family": { "const": "tokens" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "governing_fact": { "type": "string", "minLength": 1 },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "value", "role", "derivation"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(color|space|stroke|measure|weight|font)\\.[a-z][a-z0-9-]*$"
          },
          "value": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "derivation": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
