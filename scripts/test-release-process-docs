#!/usr/bin/env bash
set -euo pipefail

workspace_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

python3 - "$workspace_root" <<'PY'
import re
import sys
from pathlib import Path

root = Path(sys.argv[1])
failures: list[str] = []


def fail(message: str) -> None:
    failures.append(message)


def require_contains(name: str, text: str, needle: str) -> None:
    if needle not in text:
        fail(f"{name} missing required text: {needle}")


def require_prose_contains(name: str, text: str, needle: str) -> None:
    normalized_text = re.sub(r"\s+", " ", text)
    normalized_needle = re.sub(r"\s+", " ", needle)
    if normalized_needle not in normalized_text:
        fail(f"{name} missing required text: {needle}")


_ONES = {
    "zero": 0, "one": 1, "two": 2, "three": 3, "four": 4, "five": 5,
    "six": 6, "seven": 7, "eight": 8, "nine": 9, "ten": 10, "eleven": 11,
    "twelve": 12, "thirteen": 13, "fourteen": 14, "fifteen": 15,
    "sixteen": 16, "seventeen": 17, "eighteen": 18, "nineteen": 19,
}
_TENS = {
    "twenty": 20, "thirty": 30, "forty": 40, "fifty": 50, "sixty": 60,
    "seventy": 70, "eighty": 80, "ninety": 90,
}


def parse_count_token(token: str) -> int | None:
    """Parse a register count written as digits ('20') or an English
    number word ('Twenty', 'twenty-one') into an int; None if unparseable.

    The register authors these counts as prose; the test consults that
    prose rather than freezing the value, so it must read either form."""
    token = token.strip().lower()
    if token.isdigit():
        return int(token)
    if token in _ONES:
        return _ONES[token]
    if token in _TENS:
        return _TENS[token]
    if "-" in token:
        tens, ones = token.split("-", 1)
        if tens in _TENS and ones in _ONES and 0 < _ONES[ones] < 10:
            return _TENS[tens] + _ONES[ones]
    return None


adr_path = root / "adr" / "0019-capability-specific-integration-verification.md"
if not adr_path.exists():
    fail("adr/0019-capability-specific-integration-verification.md exists")
    adr_text = ""
else:
    adr_text = adr_path.read_text(encoding="utf-8")

if adr_text:
    require_contains(
        "ADR-0019",
        adr_text,
        "# ADR-0019: Capability-Specific Integration Verification",
    )
    require_contains("ADR-0019", adr_text, "**Status:** Accepted")
    require_contains(
        "ADR-0019",
        adr_text,
        "Verifiable Completion",
    )
    require_prose_contains(
        "ADR-0019",
        adr_text,
        "minor or major ecosystem release requires a capability-specific integration exercise",
    )
    require_prose_contains(
        "ADR-0019",
        adr_text,
        "patch ecosystem release does not add that exercise",
    )
    require_contains(
        "ADR-0019",
        adr_text,
        "ADR-0014",
    )
    require_contains(
        "ADR-0019",
        adr_text,
        "clean acid-test-blocking-friction ledger",
    )
    require_contains(
        "ADR-0019",
        adr_text,
        "Substrate-defect friction blocks",
    )
    require_contains(
        "ADR-0019",
        adr_text,
        "Capability-shape friction is recorded as a change-vector",
    )

register_text = (root / "adr" / "README.md").read_text(encoding="utf-8")
require_contains(
    "ADR register",
    register_text,
    "[0019](0019-capability-specific-integration-verification.md) | Capability-Specific Integration Verification | Accepted | Verifiable Completion (primary), Sequence, Honest Signal | extends 0011/0014 | Minor and major ecosystem releases exercise the new or changed operator-facing capability before stable publication; patch releases retain the fixture-only gate",
)
require_contains(
    "ADR register",
    register_text,
    "Verification: the table has one row per `adr/*.md` decision file",
)

row_lines = [
    line
    for line in register_text.splitlines()
    if re.match(r"^\| \[[0-9]{4}\]\([^)]*\.md\) \|", line)
]
decision_files = [
    path
    for path in (root / "adr").glob("*.md")
    if path.name != "README.md"
]
if len(row_lines) != len(decision_files):
    fail(
        "ADR register row count matches decision files "
        f"({len(row_lines)} rows, {len(decision_files)} files)"
    )

# Counts are derived from substrate and the register prose is checked
# against them — never frozen as literals in this test. The single home
# of each count is the substrate: decision-file count for the total row
# count, and the table's Status column for the superseded/active split.
# The register (an authored index) states each count in prose; this test
# consults that prose and asserts it matches the derived value, so an ADR
# add/supersede requires no edit here and a drifted register count fails.
superseded_rows = [
    line
    for line in row_lines
    if len(line.split("|")) > 3 and line.split("|")[3].strip() == "Superseded"
]
derived_active = len(decision_files) - len(superseded_rows)

active_match = re.search(
    r"([A-Za-z]+(?:-[A-Za-z]+)?|\d+)\s+genuine ecosystem decisions remain active\.",
    register_text,
)
if active_match is None:
    fail(
        "ADR register states the active-decision count "
        "('<count> genuine ecosystem decisions remain active.')"
    )
else:
    stated_active = parse_count_token(active_match.group(1))
    if stated_active is None:
        fail(
            "ADR register active-decision count is an unparseable token: "
            f"{active_match.group(1)!r}"
        )
    elif stated_active != derived_active:
        fail(
            "ADR register active-decision count matches derived "
            f"(states {active_match.group(1)!r} = {stated_active}, derived "
            f"{derived_active} = {len(decision_files)} files "
            f"- {len(superseded_rows)} superseded)"
        )

rowcount_match = re.search(
    r"equals the row count \((\d+)\)\.",
    register_text,
)
if rowcount_match is None:
    fail(
        "ADR register Verification line states the row count "
        "('equals the row count (<N>).')"
    )
elif int(rowcount_match.group(1)) != len(decision_files):
    fail(
        "ADR register stated row count matches decision files "
        f"(states {rowcount_match.group(1)}, {len(decision_files)} files)"
    )

ecosystem_text = (root / "ECOSYSTEM-RELEASE.md").read_text(encoding="utf-8")
for criterion in [
    "the session reaches a terminal success state, rather than stopping blocked\n  mid-protocol;",
    "the session progresses past every artifact-producing protocol's deliver\n  step without schema-validation failures from envelope or identity-in-body\n  mismatches;",
    "the agent delivers artifacts through the MCP tools, with no direct writes\n  to `.runa/workspace/`.",
]:
    require_contains("ECOSYSTEM-RELEASE.md", ecosystem_text, criterion)

require_prose_contains(
    "ECOSYSTEM-RELEASE.md",
    ecosystem_text,
    "For minor and major ecosystem releases, stable publication also requires a capability-specific integration exercise",
)
require_prose_contains(
    "ECOSYSTEM-RELEASE.md",
    ecosystem_text,
    "For patch ecosystem releases, the canonical fixture gate above is the complete integration-verification gate",
)
require_contains(
    "ECOSYSTEM-RELEASE.md",
    ecosystem_text,
    "[ADR-0014](adr/0014-component-independent-versioning.md)",
)
require_contains(
    "ECOSYSTEM-RELEASE.md",
    ecosystem_text,
    "[ADR-0019](adr/0019-capability-specific-integration-verification.md)",
)
require_prose_contains(
    "ECOSYSTEM-RELEASE.md",
    ecosystem_text,
    "clean acid-test-blocking-friction ledger",
)

if failures:
    for message in failures:
        print(f"not ok - {message}", file=sys.stderr)
    sys.exit(1)

print("ok - release-process documentation contract")
PY
