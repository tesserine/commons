#!/usr/bin/env python3
"""Validate the canonical intent v2 schema against its contract fixtures."""

from __future__ import annotations

import json
import sys
from pathlib import Path

import jsonschema


REPO_ROOT = Path(__file__).resolve().parents[1]
SCHEMA_PATH = REPO_ROOT / "schemas" / "intent" / "v2" / "intent.schema.json"


def load_schema() -> dict:
    return json.loads(SCHEMA_PATH.read_text(encoding="utf-8"))


def assert_valid(validator: jsonschema.Validator, document: dict) -> None:
    validator.validate(document)


def assert_invalid(validator: jsonschema.Validator, document: dict, label: str) -> None:
    try:
        validator.validate(document)
    except jsonschema.ValidationError:
        return
    raise AssertionError(f"{label} unexpectedly validated")


def assert_contract_shape(schema: dict) -> None:
    assert schema.get("$schema") == "https://json-schema.org/draft/2020-12/schema"
    assert schema.get("title") == "Intent"
    assert "Version 2.0.0" in schema.get("description", "")
    assert "INTENT.md is authoritative" in schema.get("description", "")
    assert schema.get("required") == ["statement", "source"]
    assert schema.get("additionalProperties") is False
    assert set(schema.get("properties", {})) == {"statement", "source", "target"}

    properties = schema["properties"]
    for name in ("statement", "source", "target"):
        assert properties[name]["type"] == "string"
        assert properties[name]["minLength"] == 1


def main() -> int:
    schema = load_schema()
    jsonschema.validators.validator_for(schema).check_schema(schema)
    assert_contract_shape(schema)

    validator = jsonschema.Draft202012Validator(schema)

    assert_valid(validator, {"statement": "reshape intent", "source": "operator"})
    assert_valid(
        validator,
        {"statement": "reshape intent", "target": "#94", "source": "operator"},
    )

    invalid_documents = {
        "description": {"description": "reshape intent", "source": "operator"},
        "references": {
            "statement": "reshape intent",
            "references": [{"kind": "ticket", "ref": "#94"}],
            "source": "operator",
        },
        "kind": {"statement": "reshape intent", "kind": "ticket", "source": "operator"},
        "ticket": {"statement": "reshape intent", "ticket": "#94", "source": "operator"},
        "request": {"request": "reshape intent", "source": "operator"},
        "target_parts": {
            "statement": "reshape intent",
            "target_owner": "tesserine",
            "target_repo": "commons",
            "target_number": 94,
            "source": "operator",
        },
        "additional": {
            "statement": "reshape intent",
            "target": "#94",
            "source": "operator",
            "extra": "not permitted",
        },
        "empty_statement": {"statement": "", "source": "operator"},
        "empty_source": {"statement": "reshape intent", "source": ""},
        "empty_target": {"statement": "reshape intent", "target": "", "source": "operator"},
    }
    for label, document in invalid_documents.items():
        assert_invalid(validator, document, label)

    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except AssertionError as error:
        print(f"intent-schema-test: {error}", file=sys.stderr)
        raise SystemExit(1)
